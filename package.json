{
  "name": "@designofadecade/salesforce-marketing-cloud",
  "version": "1.4.0",
  "description": "Salesforce Marketing Cloud SDK for Node.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "salesforce",
    "marketing-cloud",
    "sfmc",
    "api",
    "sdk"
  ],
  "author": "Design of a Decade <info@designofadecade.com>",
  "license": "MIT",
  "dependencies": {
    "soap": "^1.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/designofadecade/salesforce-marketing-cloud.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
